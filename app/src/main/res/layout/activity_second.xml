<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".SecondActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        tools:ignore="UseSwitchCompatOrMaterialXml">

        <Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:title="@string/article_title"
            android:navigationIcon="@drawable/arrow_back" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="20dp" />

        <TextView
            android:id="@+id/textViewTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Экзопланета TRAPPIST-1e: близнец Земли?"
            android:textSize="20dp"
            android:textColor="@color/black"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/textViewContent1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Среди семи планет системы TRAPPIST-1 особое внимание учёных привлекает четвёртая — TRAPPIST-1e."
            android:textSize="16dp"
            android:textColor="@color/black"
            android:layout_marginBottom="20dp" />

        <ImageView
            android:id="@+id/imageViewArticle"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:src="@drawable/trappist"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/textViewContent2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Система TRAPPIST-1 расположена примерно в 40 световых годах от Земли. В её центре — холодный красный карлик, вокруг которого тесно вращаются семь планет земного типа. TRAPPIST-1e по размеру и массе очень близка к нашей планете, а главное — находится в так называемой обитаемой зоне, где на поверхности теоретически может существовать жидкая вода."
            android:textSize="16dp"
            android:textAlignment="textStart"
            android:textColor="@color/black"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/textViewContent3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Именно TRAPPIST-1e чаще других называют одним из лучших кандидатов на роль «второй Земли». Наблюдения «Джеймса Уэбба» помогут понять, есть ли у неё атмосфера и из чего она состоит. Окончательных ответов пока нет, но эта далёкая планета остаётся одной из самых интригующих целей в поисках жизни за пределами Солнечной системы."
            android:textSize="16dp"
            android:textAlignment="textStart"
            android:textColor="@color/black"
            android:layout_marginBottom="20dp" />

        <Switch
            android:id="@+id/switchButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Прочитано"
            android:textSize="16dp" />

    </LinearLayout>

</ScrollView>